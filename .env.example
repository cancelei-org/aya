# Database configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/orboh"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Anthropic Claude API
# Get your API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL_OPUS=claude-opus-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-5-20251015

# OpenAI API (legacy, being migrated to Claude)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Octopart/Nexar API (for component pricing)
# Get your API key at: https://nexar.com/api
NEXT_PUBLIC_OCTOPART_API_KEY=your-octopart-api-key-here

# Perplexity API (for real-time pricing data)
# Get your API key at: https://docs.perplexity.ai/getting-started
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_API_URL=https://api.perplexity.ai

# Google Custom Search API (for purchase links)
# Get your API key at: https://console.cloud.google.com/apis/credentials
# Create search engine at: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here
USE_GOOGLE_SEARCH=true

# Realtime WebSocket Proxy
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:8080/realtime
REALTIME_PROXY_PORT=8080

# Price cache configuration
PRICE_CACHE_TTL=14400
API_RATE_LIMIT=3
MONTHLY_API_LIMIT=10000

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Feature flags
NEXT_PUBLIC_ENABLE_STREAMING=true
NEXT_PUBLIC_DISABLE_TELEMETRY=1
