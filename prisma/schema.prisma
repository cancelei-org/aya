generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id             String      @id @default(cuid())
  name           String?
  email          String      @unique
  emailVerified  DateTime?   @map("email_verified")
  image          String?
  chatCount      Int         @default(0) @map("chat_count")
  isPremium      Boolean     @default(false) @map("is_premium")
  subscriptionId String?     @map("subscription_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  isAdmin        Boolean     @default(false) @map("is_admin")
  lastActiveAt   DateTime?   @map("last_active_at")
  accounts       Account[]
  projects       Project[]
  sessions       Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Project {
  id              String                 @id @default(cuid())
  userId          String                 @map("user_id")
  name            String
  description     String?
  nodesData       String?                @map("nodes_data")
  connectionsData String?                @map("connections_data")
  pbsStructure    String?                @map("pbs_structure")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  canvas_nodes    canvas_nodes[]
  chatMessages    ChatMessage[]
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  requirements    RequirementsDocument[]

  @@map("projects")
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  role      String
  content   String
  timestamp DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([timestamp])
  @@map("chat_messages")
}


model Feedback {
  id        String   @id @default(cuid())
  userEmail String   @map("user_email")
  userName  String   @map("user_name")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedback")
}


model canvas_connections {
  id                                                    String       @id
  from_id                                               String
  to_id                                                 String
  from_port                                             String       @default("output-center")
  to_port                                               String       @default("input-center")
  canvas_nodes_canvas_connections_from_idTocanvas_nodes canvas_nodes @relation("canvas_connections_from_idTocanvas_nodes", fields: [from_id], references: [id], onDelete: Cascade)
  canvas_nodes_canvas_connections_to_idTocanvas_nodes   canvas_nodes @relation("canvas_connections_to_idTocanvas_nodes", fields: [to_id], references: [id], onDelete: Cascade)
}

model canvas_nodes {
  id                                                          String               @id
  project_id                                                  String
  title                                                       String
  x                                                           Float
  y                                                           Float
  type                                                        String
  sub_label                                                   String?
  inputs                                                      Int                  @default(0)
  outputs                                                     Int                  @default(0)
  voltage                                                     String?
  communication                                               String?
  description                                                 String?
  model_number                                                String?
  order_status                                                String?              @default("Unordered")
  estimated_order_date                                        DateTime?
  purchase_site_link                                          String?
  quantity                                                    Int?                 @default(1)
  created_at                                                  DateTime             @default(now())
  updated_at                                                  DateTime
  cached_pricing                                              Json?
  pricing_updated_at                                          DateTime?
  canvas_connections_canvas_connections_from_idTocanvas_nodes canvas_connections[] @relation("canvas_connections_from_idTocanvas_nodes")
  canvas_connections_canvas_connections_to_idTocanvas_nodes   canvas_connections[] @relation("canvas_connections_to_idTocanvas_nodes")
  projects                                                    Project              @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([estimated_order_date], map: "idx_canvas_nodes_order_date")
  @@index([order_status], map: "idx_canvas_nodes_order_status")
  @@index([pricing_updated_at], map: "idx_canvas_nodes_pricing_updated")
}

model RequirementsDocument {
  id          String            @id @default(cuid())
  projectId   String            @map("project_id")
  title       String
  content     Json
  contentHtml String?           @map("content_html")
  contentText String?           @map("content_text")
  status      RequirementStatus @default(DRAFT)
  approvedAt  DateTime?         @map("approved_at")
  approvedBy  String?           @map("approved_by")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  version     Int               @default(1)
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("requirements_documents")
}

model ComponentSpecification {
  id            String   @id @default(cuid())
  partName      String   @unique
  modelNumber   String?
  category      String
  manufacturer  String?
  specification Json
  dynamicPorts  Json?
  isPreset      Boolean  @default(true)
  confidence    Float    @default(1.0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([partName])
  @@index([category])
  @@map("component_specifications")
}

enum RequirementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}
